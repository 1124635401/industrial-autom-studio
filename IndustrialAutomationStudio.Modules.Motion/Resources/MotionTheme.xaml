    <Geometry x:Key="MotionIcon.Log">M5,2 L16,2 21,7 21,22 5,22 Z M16,2 L16,7 21,7 M9,11 L17,11 M9,15 L17,15 M9,19 L15,19</Geometry>
    <Geometry x:Key="MotionIcon.Card">M2,5 L22,5 22,19 2,19 Z M6,9 L10,9 10,13 6,13 Z M14,10 L18,10 M14,14 L18,14</Geometry>
    <Geometry x:Key="MotionIcon.DigitalInput">M3,4 L18,4 18,20 3,20 Z M8,12 L21,12 M16,7 L21,12 16,17</Geometry>
    <Geometry x:Key="MotionIcon.DigitalOutput">M6,4 L21,4 21,20 6,20 Z M3,12 L16,12 M11,7 L16,12 11,17</Geometry>

    <Style x:Key="MotionPageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="27" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MotionBrush.Text}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MotionNavigationToggleStyle" TargetType="ToggleButton">
        <Setter Property="Height" Value="56" />
        <Setter Property="Margin" Value="8,2" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid>
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <Border x:Name="SelectionRail" Width="4" Height="34"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Background="{StaticResource MotionBrush.Primary}"
                                CornerRadius="0,3,3,0" Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#FFF1F5FA" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource MotionPrimaryHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource MotionBrush.Primary}" />
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource MotionPrimaryLightBrush}" />
                            <Setter TargetName="SelectionRail" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource MotionBrush.Primary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MotionMetricCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MotionCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="MotionInfoBannerStyle" TargetType="Border">
        <Setter Property="Background" Value="#FFF3F7FF" />
        <Setter Property="BorderBrush" Value="#FFB8D5FF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="18,14" />
    </Style>

    <Style x:Key="MotionIconButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="40" />
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource MotionPrimaryLightBrush}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#FF91BAF4" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource MotionPrimaryHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource MotionBrush.Primary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MotionStatusPillStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Background" Value="{StaticResource MotionDisabledBrush}" />
    </Style>

    <Style x:Key="MotionEmptyStateCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MotionCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Width" Value="460" />
        <Setter Property="Padding" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MotionDataGridStyle" TargetType="DataGrid">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="#FFE7ECF2" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="RowHeight" Value="46" />
        <Setter Property="ColumnHeaderHeight" Value="42" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="AlternatingRowBackground" Value="#FFFCFDFE" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FFF7F9FC" />
                    <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource MotionBorderBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="Padding" Value="14,0" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="CellStyle">
            <Setter.Value>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="14,0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
                            <Setter Property="Background" Value="Transparent" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="RowStyle">
            <Setter.Value>
                <Style TargetType="DataGridRow">
                    <Setter Property="BorderThickness" Value="0" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#FFF5F8FC" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource MotionPrimaryLightBrush}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MotionNavigationButton" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="22,12" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2AFFFFFF" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MotionPrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource MotionBrush.Primary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="72" />
    </Style>

    <Style x:Key="MotionSecondaryButton" TargetType="Button">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="72" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource MotionCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource MotionPrimaryLightBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource MotionBrush.Primary}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource MotionDisabledBrush}" />
                <Setter Property="Foreground" Value="{StaticResource MotionTextSecondaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MotionDangerOutlineButton" TargetType="Button" BasedOn="{StaticResource MotionSecondaryButton}">
        <Setter Property="Foreground" Value="{StaticResource MotionDangerBrush}" />
        <Setter Property="BorderBrush" Value="#FFF0B8B8" />
    </Style>

    <Style x:Key="MotionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource MotionCardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="MotionCardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
    </Style>

    <Style x:Key="MotionFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource MotionTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <ControlTemplate x:Key="MotionValidationErrorTemplate">
        <DockPanel LastChildFill="True">
            <Border BorderBrush="{StaticResource MotionDangerBrush}" BorderThickness="1" CornerRadius="4">
                <AdornedElementPlaceholder />
            </Border>
            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
                       Foreground="{StaticResource MotionDangerBrush}" FontWeight="Bold" Text="!" />
        </DockPanel>
    </ControlTemplate>

    <Style x:Key="MotionInputStyle" TargetType="TextBox">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionBorderBrush}" />
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource MotionValidationErrorTemplate}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource MotionBrush.Primary}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{StaticResource MotionDisabledBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MotionComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="36" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionBorderBrush}" />
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource MotionValidationErrorTemplate}" />
    </Style>

    <Style x:Key="MotionAxisListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemBorder" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource MotionPrimaryLightBrush}" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource MotionBrush.Primary}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#FFF6F8FC" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MotionReferenceCardStyle" TargetType="Border">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="9" ShadowDepth="1" Opacity="0.06" Color="#FF6C7A90" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MotionReferenceToolbarButton" TargetType="Button">
        <Setter Property="Height" Value="{DynamicResource MotionAxisToolbarButtonHeight}" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Padding" Value="13,0" />
        <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource MotionReferenceBlueLightBrush}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#FF9CC2FA" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="#FFE4EFFF" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.48" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MotionReferenceActionButton" TargetType="Button" BasedOn="{StaticResource MotionReferenceToolbarButton}">
        <Setter Property="Height" Value="{DynamicResource MotionAxisActionButtonHeight}" />
        <Setter Property="MinWidth" Value="96" />
        <Setter Property="Margin" Value="0,0,9,0" />
        <Setter Property="Padding" Value="11,0" />
    </Style>

    <Style x:Key="MotionReferenceAxisListItemStyle" TargetType="ListBoxItem">
        <Setter Property="Margin" Value="0,0,0,3" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemChrome" MinHeight="44" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="#FFF7FAFF" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource MotionReferenceBlueLightBrush}" />
                            <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#FF8DB9F8" />
                            <Setter Property="Foreground" Value="{StaticResource MotionReferenceBlueBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MotionReferenceInputStyle" TargetType="TextBox">
        <Setter Property="Height" Value="{DynamicResource MotionAxisInputHeight}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="9,4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource MotionValidationErrorTemplate}" />
        <Style.Triggers>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBlueBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MotionReferenceComboStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="{DynamicResource MotionAxisInputHeight}" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Padding" Value="7,3" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBorderBrush}" />
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource MotionValidationErrorTemplate}" />
    </Style>

    <Style x:Key="MotionReferenceFieldLabel" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MotionReferenceCardTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MotionReferenceTitleBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MotionAxisBasicColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#FFEAF2FF" />
        <Setter Property="Foreground" Value="{StaticResource MotionReferenceTitleBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="9,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="MotionAxisMotionColumnHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource MotionAxisBasicColumnHeaderStyle}">
        <Setter Property="Background" Value="#FFEAF7F3" />
    </Style>
    <Style x:Key="MotionAxisHomeColumnHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource MotionAxisBasicColumnHeaderStyle}">
        <Setter Property="Background" Value="#FFFFF4E5" />
    </Style>
    <Style x:Key="MotionAxisPdoColumnHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource MotionAxisBasicColumnHeaderStyle}">
        <Setter Property="Background" Value="#FFF2EDFF" />
    </Style>

    <Style x:Key="MotionAxisDataGridStyle" TargetType="DataGrid">
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="#FFE8ECF2" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="RowHeight" Value="38" />
        <Setter Property="ColumnHeaderHeight" Value="36" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="AlternatingRowBackground" Value="#FFFBFCFE" />
        <Setter Property="RowBackground" Value="White" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#FFF2F4F7" />
                    <Setter Property="Foreground" Value="{StaticResource MotionReferenceTitleBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBorderBrush}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="CellStyle">
            <Setter.Value>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="10,0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                    <Setter Property="Validation.ErrorTemplate" Value="{StaticResource MotionValidationErrorTemplate}" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource MotionReferenceTitleBrush}" />
                            <Setter Property="Background" Value="Transparent" />
                        </Trigger>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource MotionDangerBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="RowStyle">
            <Setter.Value>
                <Style TargetType="DataGridRow">
                    <Setter Property="BorderThickness" Value="0" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource MotionReferenceBlueLightBrush}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MotionAxisUnderlineTextBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource MotionReferenceInputStyle}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="3,2" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#FF9EABC0" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBlueBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource MotionReferenceSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="#FFE1E6EF" />
            </Trigger>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource MotionDangerBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,2" />
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MotionAxisUnderlineComboBoxStyle"
           TargetType="ComboBox"
           BasedOn="{StaticResource MotionReferenceComboStyle}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="3,2" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="UnderlineBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  IsHitTestVisible="False"
                                                  RecognizesAccessKey="True"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                                <Path Width="8" Height="5" Margin="0,0,7,0"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"
                                      IsHitTestVisible="False" Stretch="Fill"
                                      Stroke="{StaticResource MotionReferenceSecondaryBrush}"
                                      StrokeThickness="1.4" Data="M0,0 L4,4 L8,0" />
                            </Grid>
                        </Border>

                        <ToggleButton x:Name="DropDownToggle"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"
                                      Opacity="0"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />

                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=DropDownToggle}"
                               PopupAnimation="Fade"
                               StaysOpen="False">
                            <Border MinWidth="{Binding PlacementTarget.ActualWidth, RelativeSource={RelativeSource AncestorType=Popup}}"
                                    MaxHeight="240" Padding="2"
                                    Background="White"
                                    BorderBrush="{StaticResource MotionReferenceBorderBrush}"
                                    BorderThickness="1" CornerRadius="3">
                                <ScrollViewer CanContentScroll="True"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#FF9EABC0" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource MotionReferenceBlueBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,2" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{StaticResource MotionReferenceSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="#FFE1E6EF" />
            </Trigger>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource MotionDangerBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,2" />
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MotionParameterCellInputStyle" TargetType="TextBox" BasedOn="{StaticResource MotionReferenceInputStyle}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="3" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="MotionParameterCellComboStyle" TargetType="ComboBox" BasedOn="{StaticResource MotionReferenceComboStyle}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="3" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Margin" Value="6" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="MinWidth" Value="130" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Margin" Value="6" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="MinWidth" Value="130" />
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Margin" Value="0,0,0,14" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</ResourceDictionary>
