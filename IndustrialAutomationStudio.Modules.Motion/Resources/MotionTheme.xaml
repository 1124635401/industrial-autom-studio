    <Color x:Key="MotionColor.Navigation">#FFFBFCFE</Color>
    <Color x:Key="MotionColor.Primary">#FF0B63E5</Color>
    <Color x:Key="MotionColor.Success">#FF21A366</Color>
    <Color x:Key="MotionColor.Warning">#FFF4A100</Color>
    <Color x:Key="MotionColor.Danger">#FFD64545</Color>
    <Color x:Key="MotionColor.Text">#FF172033</Color>
    <Color x:Key="MotionColor.Muted">#FF667085</Color>

    <SolidColorBrush x:Key="MotionBrush.Background" Color="{StaticResource MotionColor.Background}" />
    <SolidColorBrush x:Key="MotionBrush.Panel" Color="{StaticResource MotionColor.Panel}" />
    <SolidColorBrush x:Key="MotionBrush.Navigation" Color="{StaticResource MotionColor.Navigation}" />
    <SolidColorBrush x:Key="MotionBrush.Primary" Color="{StaticResource MotionColor.Primary}" />
    <SolidColorBrush x:Key="MotionBrush.Success" Color="{StaticResource MotionColor.Success}" />
    <SolidColorBrush x:Key="MotionBrush.Warning" Color="{StaticResource MotionColor.Warning}" />
    <SolidColorBrush x:Key="MotionBrush.Danger" Color="{StaticResource MotionColor.Danger}" />
    <SolidColorBrush x:Key="MotionBrush.Text" Color="{StaticResource MotionColor.Text}" />
    <SolidColorBrush x:Key="MotionBrush.Muted" Color="{StaticResource MotionColor.Muted}" />

    <SolidColorBrush x:Key="MotionPrimaryLightBrush" Color="#FFEAF2FF" />
    <SolidColorBrush x:Key="MotionPrimaryHoverBrush" Color="#FFDCEBFF" />
    <SolidColorBrush x:Key="MotionPageBackgroundBrush" Color="#FFF7F9FC" />
    <SolidColorBrush x:Key="MotionCardBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MotionBorderBrush" Color="#FFDCE3ED" />
    <SolidColorBrush x:Key="MotionTextPrimaryBrush" Color="#FF172033" />
    <SolidColorBrush x:Key="MotionTextSecondaryBrush" Color="#FF667085" />
    <SolidColorBrush x:Key="MotionDangerBrush" Color="#FFD64545" />
    <SolidColorBrush x:Key="MotionDisabledBrush" Color="#FFF1F3F6" />
    <SolidColorBrush x:Key="MotionSuccessLightBrush" Color="#FFE9F8EE" />
    <SolidColorBrush x:Key="MotionDangerLightBrush" Color="#FFFDEBEC" />
    <SolidColorBrush x:Key="MotionWarningLightBrush" Color="#FFFFF6E5" />
    <SolidColorBrush x:Key="MotionPurpleBrush" Color="#FF6C4ED9" />
    <SolidColorBrush x:Key="MotionPurpleLightBrush" Color="#FFF0ECFF" />

    <!-- Axis configuration reference design -->
    <SolidColorBrush x:Key="MotionReferenceBlueBrush" Color="#FF0B63E5" />
    <SolidColorBrush x:Key="MotionReferenceBlueLightBrush" Color="#FFF0F6FF" />
    <SolidColorBrush x:Key="MotionReferencePageBrush" Color="#FFF7F9FC" />
    <SolidColorBrush x:Key="MotionReferenceBorderBrush" Color="#FFDCE3ED" />
    <SolidColorBrush x:Key="MotionReferenceTitleBrush" Color="#FF102A56" />
    <SolidColorBrush x:Key="MotionReferenceSecondaryBrush" Color="#FF63728A" />

    <!-- Host applications may override these density resources. -->
    <GridLength x:Key="MotionChromeHeight">54</GridLength>
    <GridLength x:Key="MotionNavigationWidth">198</GridLength>
    <GridLength x:Key="MotionStatusBarHeight">44</GridLength>
    <sys:Double x:Key="MotionAxisToolbarButtonHeight">36</sys:Double>
    <sys:Double x:Key="MotionAxisActionButtonHeight">36</sys:Double>
    <sys:Double x:Key="MotionAxisInputHeight">36</sys:Double>
    <sys:Double x:Key="MotionAxisParameterMinWidth">840</sys:Double>
    <sys:Double x:Key="MotionAxisParameterMinHeight">580</sys:Double>
    <GridLength x:Key="MotionAxisTableHeight">220</GridLength>
    <GridLength x:Key="MotionAxisHeaderHeight">72</GridLength>
    <GridLength x:Key="MotionAxisCardHeaderHeight">50</GridLength>
    <GridLength x:Key="MotionAxisListWidth">280</GridLength>
    <GridLength x:Key="MotionAxisStatusHeight">48</GridLength>

    <converters:EqualityConverter x:Key="MotionEqualityConverter" />

