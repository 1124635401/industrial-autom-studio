<UserControl x:Class="IndustrialAutomationStudio.Modules.Motion.Views.AxisConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:controls="clr-namespace:IndustrialAutomationStudio.Modules.Motion.Views.Controls"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{StaticResource MotionReferencePageBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{DynamicResource MotionAxisHeaderHeight}" />
            <RowDefinition Height="*" />
            <RowDefinition Height="{DynamicResource MotionAxisStatusHeight}" />
        </Grid.RowDefinitions>

        <controls:AxisConfigurationHeader />
        <controls:AxisConfigurationTablePanel Grid.Row="1" Margin="14,12" />
        <controls:ConfigurationStatusBar Grid.Row="2" Margin="14,0,14,6" />
    </Grid>
</UserControl>
