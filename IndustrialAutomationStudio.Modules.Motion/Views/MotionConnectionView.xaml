<UserControl x:Class="IndustrialAutomationStudio.Modules.Motion.Views.MotionConnectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="Transparent"
             SizeChanged="MotionConnectionView_OnSizeChanged">
    <UserControl.Resources>
        <Style x:Key="ConnectionSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
        </Style>
        <Style x:Key="ConnectionHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MotionTextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="ConnectionValidationStyle" TargetType="TextBlock">
            <Setter Property="MinHeight" Value="16" />
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MotionDangerBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="ConnectionDetailLabelStyle" TargetType="TextBlock"
               BasedOn="{StaticResource MotionFieldLabelStyle}">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ConnectionDetailValueStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Foreground" Value="{StaticResource MotionTextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="ConnectionMetricCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="#FFFAFBFD" />
            <Setter Property="BorderBrush" Value="{StaticResource MotionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style x:Key="ConnectionAdvancedExpanderStyle" TargetType="Expander">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderToggle"
                                          Content="{TemplateBinding Header}"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          Foreground="{StaticResource MotionTextPrimaryBrush}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="HeaderChrome"
                                                Padding="14,11"
                                                Background="#FFFAFBFD"
                                                BorderBrush="{StaticResource MotionBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="28" Height="28" Margin="0,0,10,0"
                                                        Background="{StaticResource MotionWarningLightBrush}"
                                                        CornerRadius="6">
                                                    <Path Width="15" Height="15" Stretch="Uniform"
                                                          Stroke="{StaticResource MotionBrush.Warning}"
                                                          StrokeThickness="1.6"
                                                          Data="{StaticResource MotionIcon.Alarm}" />
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <ContentPresenter />
                                                    <TextBlock Margin="0,2,0,0"
                                                               Style="{StaticResource ConnectionHintStyle}"
                                                               Text="急停极性和动作码，通常保持设备默认值。" />
                                                </StackPanel>
                                                <Path x:Name="AdvancedChevron" Grid.Column="2"
                                                      Width="9" Height="5" Margin="14,0,2,0"
                                                      VerticalAlignment="Center" Stretch="Fill"
                                                      Stroke="{StaticResource MotionTextSecondaryBrush}"
                                                      StrokeThickness="1.5" Data="M0,0 L4.5,4.5 L9,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HeaderChrome" Property="BorderBrush" Value="#FF9CBCEB" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="HeaderChrome" Property="BorderBrush"
                                                        Value="{StaticResource MotionBrush.Primary}" />
                                                <Setter TargetName="AdvancedChevron" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" CenterX="4.5" CenterY="2.5" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Margin="0,14,0,0"
                                              HorizontalAlignment="Stretch"
                                              ContentSource="Content"
                                              Visibility="Collapsed" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource MotionPageTitleStyle}"
                               Text="控制卡连接" />
                    <TextBlock Margin="0,7,0,0"
                               FontSize="13"
                               Foreground="{StaticResource MotionTextSecondaryBrush}"
                               Text="配置并连接运动控制卡，查看 EtherCAT 与轴资源状态。" />
                </StackPanel>

                <Border Grid.Column="1"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource MotionStatusPillStyle}">
                            <Setter Property="Background" Value="{StaticResource MotionDisabledBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource MotionSuccessLightBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource MotionPrimaryLightBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FFAEB7C5" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource MotionBrush.Success}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource MotionBrush.Primary}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="未连接" />
                                    <Setter Property="Foreground" Value="{StaticResource MotionTextSecondaryBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="已连接" />
                                            <Setter Property="Foreground" Value="{StaticResource MotionBrush.Success}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="Text" Value="处理中" />
                                            <Setter Property="Foreground" Value="{StaticResource MotionBrush.Primary}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="WorkspaceGrid" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="ConfigurationCard"
                        Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource MotionCardStyle}"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Padding="22,18"
                                Background="#FFFAFBFD"
                                BorderBrush="{StaticResource MotionBorderBrush}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource MotionCardTitleStyle}"
                                               Text="连接配置" />
                                    <TextBlock Margin="0,5,0,0"
                                               Style="{StaticResource ConnectionHintStyle}"
                                               Text="连接前会自动保存当前配置。" />
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Padding="10,5"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource MotionPrimaryLightBrush}"
                                        CornerRadius="12">
                                    <TextBlock FontSize="12"
                                               Foreground="{StaticResource MotionBrush.Primary}"
                                               Text="凌臣 M60" />
                                </Border>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="22,20,22,22">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Border Width="28" Height="28"
                                        Margin="0,0,10,0"
                                        Background="{StaticResource MotionPrimaryLightBrush}"
                                        CornerRadius="6">
                                    <Path Width="15" Height="15" Stretch="Uniform"
                                          Stroke="{StaticResource MotionBrush.Primary}"
                                          StrokeThickness="1.6"
                                          Data="{StaticResource MotionIcon.Card}" />
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource ConnectionSectionTitleStyle}"
                                               Text="基础配置" />
                                    <TextBlock Margin="0,2,0,0"
                                               Style="{StaticResource ConnectionHintStyle}"
                                               Text="选择板卡驱动并指定板卡编号。" />
                                </StackPanel>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,7"
                                               Style="{StaticResource MotionFieldLabelStyle}"
                                               Text="板卡驱动" />
                                    <ComboBox IsEnabled="{Binding CanEditConfiguration}"
                                              ItemsSource="{Binding AvailableDriverKeys}"
                                              SelectedItem="{Binding SelectedDriverKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource MotionComboBoxStyle}" />
                                    <TextBlock Style="{StaticResource ConnectionValidationStyle}"
                                               Text="{Binding DriverValidationMessage}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,7"
                                               Style="{StaticResource MotionFieldLabelStyle}"
                                               Text="板卡号" />
                                    <TextBox IsEnabled="{Binding CanEditConfiguration}"
                                             Text="{Binding CardNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MotionInputStyle}" />
                                    <TextBlock Style="{StaticResource ConnectionValidationStyle}"
                                               Text="{Binding CardNoValidationMessage}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,18,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLctM60Selected}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <Border Width="28" Height="28"
                                            Margin="0,0,10,0"
                                            Background="{StaticResource MotionPurpleLightBrush}"
                                            CornerRadius="6">
                                        <Path Width="15" Height="15" Stretch="Uniform"
                                              Stroke="{StaticResource MotionPurpleBrush}"
                                              StrokeThickness="1.6"
                                              Data="{StaticResource MotionIcon.Connection}" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource ConnectionSectionTitleStyle}"
                                                   Text="M60 EtherCAT" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Style="{StaticResource ConnectionHintStyle}"
                                                   Text="指定 ENI 网络配置和从站参数文件。" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                    <TextBlock Margin="0,0,0,7"
                                               Style="{StaticResource MotionFieldLabelStyle}"
                                               Text="EtherCAT ENI 文件" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox IsEnabled="{Binding CanEditConfiguration}"
                                                 Text="{Binding EniFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{Binding EniFilePath}"
                                                 Style="{StaticResource MotionInputStyle}" />
                                        <Button Grid.Column="1" Width="84" Margin="10,0,0,0"
                                                Command="{Binding SelectEniFileCommand}"
                                                Style="{StaticResource MotionSecondaryButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Width="14" Height="14" Margin="0,0,7,0" Stretch="Uniform"
                                                      Stroke="{StaticResource MotionTextPrimaryBrush}"
                                                      StrokeThickness="1.5"
                                                      Data="{StaticResource MotionIcon.Folder}" />
                                                <TextBlock Text="选择" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <TextBlock Style="{StaticResource ConnectionValidationStyle}"
                                               Text="{Binding EniFileValidationMessage}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                                    <TextBlock Margin="0,0,0,7"
                                               Style="{StaticResource MotionFieldLabelStyle}"
                                               Text="从站参数文件" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox IsEnabled="{Binding CanEditConfiguration}"
                                                 Text="{Binding SlaveParameterFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{Binding SlaveParameterFilePath}"
                                                 Style="{StaticResource MotionInputStyle}" />
                                        <Button Grid.Column="1" Width="84" Margin="10,0,0,0"
                                                Command="{Binding SelectSlaveParameterFileCommand}"
                                                Style="{StaticResource MotionSecondaryButton}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Width="14" Height="14" Margin="0,0,7,0" Stretch="Uniform"
                                                      Stroke="{StaticResource MotionTextPrimaryBrush}"
                                                      StrokeThickness="1.5"
                                                      Data="{StaticResource MotionIcon.Folder}" />
                                                <TextBlock Text="选择" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <TextBlock Style="{StaticResource ConnectionValidationStyle}"
                                               Text="{Binding SlaveParameterFileValidationMessage}" />
                                </StackPanel>

                                <Expander Grid.Row="3"
                                          Header="高级设置"
                                          IsExpanded="False"
                                          Style="{StaticResource ConnectionAdvancedExpanderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,7"
                                                       Style="{StaticResource MotionFieldLabelStyle}"
                                                       Text="急停输入极性" />
                                            <ComboBox IsEnabled="{Binding CanEditConfiguration}"
                                                      ItemsSource="{Binding EmergencyPolarityOptions}"
                                                      DisplayMemberPath="Value"
                                                      SelectedValuePath="Key"
                                                      SelectedValue="{Binding EmergencyInputInverted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource MotionComboBoxStyle}" />
                                            <TextBlock Style="{StaticResource ConnectionValidationStyle}"
                                                       Text="{Binding EmergencyInputValidationMessage}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Margin="0,0,0,7"
                                                       Style="{StaticResource MotionFieldLabelStyle}"
                                                       Text="急停动作码（0–255）" />
                                            <TextBox IsEnabled="{Binding CanEditConfiguration}"
                                                     Text="{Binding EmergencyAction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource MotionInputStyle}" />
                                            <TextBlock Style="{StaticResource ConnectionValidationStyle}"
                                                       Text="{Binding EmergencyActionValidationMessage}" />
                                            <TextBlock Margin="0,1,0,0"
                                                       Style="{StaticResource ConnectionHintStyle}"
                                                       Text="动作码含义请以凌臣 M60 手册为准。" />
                                        </StackPanel>
                                    </Grid>
                                </Expander>
                            </Grid>

                            <Border Margin="0,18,0,0"
                                    Style="{StaticResource MotionInfoBannerStyle}"
                                    Padding="14,11">
                                <StackPanel Orientation="Horizontal">
                                    <Path Width="17" Height="17" Margin="0,0,10,0" Stretch="Uniform"
                                          Stroke="{StaticResource MotionBrush.Primary}"
                                          StrokeThickness="1.6"
                                          Data="{StaticResource MotionIcon.Info}" />
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="12"
                                               Foreground="{StaticResource MotionBrush.Primary}"
                                               TextWrapping="Wrap"
                                               Text="请确保当前 Driver、ENI 网络和 M60 从站参数与现场硬件一致。" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Padding="22,16"
                                Background="#FFFAFBFD"
                                BorderBrush="{StaticResource MotionBorderBrush}"
                                BorderThickness="0,1,0,0"
                                CornerRadius="0,0,8,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource ConnectionHintStyle}"
                                           Text="配置修改仅在未连接时可用。" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Command="{Binding SaveConfigurationCommand}"
                                            Content="保存配置"
                                            Style="{StaticResource MotionSecondaryButton}" />
                                    <Button Command="{Binding ScanCommand}"
                                            Content="扫描轴"
                                            Style="{StaticResource MotionSecondaryButton}" />
                                    <Button Command="{Binding DisconnectCommand}"
                                            Content="断开"
                                            Style="{StaticResource MotionDangerOutlineButton}" />
                                    <Button Margin="0" Command="{Binding ConnectCommand}"
                                            Style="{StaticResource MotionPrimaryButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="15" Height="15" Margin="0,0,7,0" Stretch="Uniform"
                                                  Stroke="White" StrokeThickness="1.6"
                                                  Data="{StaticResource MotionIcon.Connection}" />
                                            <TextBlock Text="连接" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border x:Name="StatusCard"
                        Grid.Row="1" Grid.Column="0"
                        Margin="0,20,0,0"
                        VerticalAlignment="Top"
                        Style="{StaticResource MotionCardStyle}"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Padding="22,18"
                                Background="#FFFAFBFD"
                                BorderBrush="{StaticResource MotionBorderBrush}"
                                BorderThickness="0,0,0,1"
                                CornerRadius="8,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource MotionCardTitleStyle}"
                                           Text="设备状态" />
                                <Border Grid.Column="1">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource MotionStatusPillStyle}">
                                            <Setter Property="Background" Value="{StaticResource MotionDisabledBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource MotionSuccessLightBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="离线" />
                                                <Setter Property="Foreground" Value="{StaticResource MotionTextSecondaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Text" Value="在线" />
                                                        <Setter Property="Foreground" Value="{StaticResource MotionBrush.Success}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>

                        <Grid x:Name="StatusContentGrid" Grid.Row="1" Margin="22,20,22,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="StatusIdentityColumn" Width="3*" />
                                <ColumnDefinition x:Name="StatusLeftGapColumn" Width="24" />
                                <ColumnDefinition x:Name="StatusMetricsColumn" Width="4*" />
                                <ColumnDefinition x:Name="StatusMiddleGapColumn" Width="24" />
                                <ColumnDefinition x:Name="StatusDetailsColumn" Width="3*" />
                                <ColumnDefinition x:Name="StatusRightGapColumn" Width="24" />
                                <ColumnDefinition x:Name="StatusResultColumn" Width="4*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border x:Name="StatusLeftSeparator" Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    BorderBrush="{StaticResource MotionBorderBrush}"
                                    BorderThickness="1,0,0,0" />
                            <Border x:Name="StatusMiddleSeparator" Grid.Column="3"
                                    HorizontalAlignment="Center"
                                    BorderBrush="{StaticResource MotionBorderBrush}"
                                    BorderThickness="1,0,0,0" />
                            <Border x:Name="StatusRightSeparator" Grid.Column="5"
                                    HorizontalAlignment="Center"
                                    BorderBrush="{StaticResource MotionBorderBrush}"
                                    BorderThickness="1,0,0,0" />

                        <StackPanel x:Name="StatusIdentityPanel"
                                    Grid.Row="0" Grid.Column="0"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="56" Height="56"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource MotionPrimaryLightBrush}"
                                    CornerRadius="28">
                                <Path Width="27" Height="27" Stretch="Uniform"
                                      Stroke="{StaticResource MotionBrush.Primary}"
                                      StrokeThickness="1.7"
                                      Data="{StaticResource MotionIcon.Card}" />
                            </Border>
                            <TextBlock Margin="0,10,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MotionTextPrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="等待连接" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Text" Value="{Binding CardName}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Margin="0,5,0,0"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource ConnectionHintStyle}"
                                       Text="运动控制卡" />
                        </StackPanel>

                        <UniformGrid x:Name="StatusMetricsPanel"
                                     Grid.Row="0" Grid.Column="2"
                                     VerticalAlignment="Center" Columns="3">
                            <Border Style="{StaticResource ConnectionMetricCardStyle}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" FontSize="24" FontWeight="SemiBold"
                                               Foreground="{StaticResource MotionBrush.Primary}" Text="{Binding AxisCount}" />
                                    <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center"
                                               Style="{StaticResource ConnectionHintStyle}" Text="轴" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ConnectionMetricCardStyle}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" FontSize="24" FontWeight="SemiBold"
                                               Foreground="{StaticResource MotionPurpleBrush}" Text="{Binding DiCount}" />
                                    <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center"
                                               Style="{StaticResource ConnectionHintStyle}" Text="DI" />
                                </StackPanel>
                            </Border>
                            <Border Margin="0" Padding="12"
                                    Background="#FFFAFBFD"
                                    BorderBrush="{StaticResource MotionBorderBrush}"
                                    BorderThickness="1" CornerRadius="6">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Center" FontSize="24" FontWeight="SemiBold"
                                               Foreground="{StaticResource MotionBrush.Success}" Text="{Binding DoCount}" />
                                    <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center"
                                               Style="{StaticResource ConnectionHintStyle}" Text="DO" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid x:Name="StatusDetailsPanel"
                              Grid.Row="0" Grid.Column="4"
                              VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="42" />
                                <RowDefinition Height="42" />
                                <RowDefinition Height="42" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Style="{StaticResource ConnectionDetailLabelStyle}" Text="配置驱动" />
                            <TextBlock Grid.Column="1" Style="{StaticResource ConnectionDetailValueStyle}"
                                       Text="{Binding SelectedDriverKey}" />

                            <Border Grid.Row="1" Grid.ColumnSpan="2" VerticalAlignment="Top"
                                    BorderBrush="{StaticResource MotionBorderBrush}" BorderThickness="0,1,0,0" />
                            <TextBlock Grid.Row="1" Style="{StaticResource ConnectionDetailLabelStyle}" Text="实际驱动" />
                            <TextBlock Grid.Row="1" Grid.Column="1">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource ConnectionDetailValueStyle}">
                                        <Setter Property="Text" Value="—" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Text" Value="{Binding DriverKey}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Border Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Top"
                                    BorderBrush="{StaticResource MotionBorderBrush}" BorderThickness="0,1,0,0" />
                            <TextBlock Grid.Row="2" Style="{StaticResource ConnectionDetailLabelStyle}" Text="固件版本" />
                            <TextBlock Grid.Row="2" Grid.Column="1">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource ConnectionDetailValueStyle}">
                                        <Setter Property="Text" Value="—" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Text" Value="{Binding FirmwareVersion}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Border x:Name="StatusResultPanel"
                                Grid.Row="0" Grid.Column="6"
                                VerticalAlignment="Center"
                                Padding="14,12"
                                Background="{StaticResource MotionPrimaryLightBrush}"
                                CornerRadius="7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path Width="17" Height="17" Margin="0,1,10,0"
                                      VerticalAlignment="Top" Stretch="Uniform"
                                      Stroke="{StaticResource MotionBrush.Primary}"
                                      StrokeThickness="1.6"
                                      Data="{StaticResource MotionIcon.Info}" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource MotionBrush.Primary}"
                                               Text="操作结果" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="{StaticResource MotionTextPrimaryBrush}"
                                               Text="{Binding StatusMessage}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
