<UserControl x:Class="IndustrialAutomationStudio.Modules.Motion.Views.MotionWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <ResourceDictionary Source="/IndustrialAutomationStudio.Modules.Motion;component/Resources/MotionTheme.xaml" />
    </UserControl.Resources>
    <Grid Background="{StaticResource MotionBrush.Background}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Background="{StaticResource MotionBrush.Navigation}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,24,0,0">
                    <TextBlock Margin="22,0,0,22" FontSize="20" FontWeight="Bold" Foreground="White" Text="运动控制" />
                    <Button Style="{StaticResource MotionNavigationButton}" Content="运动首页" Command="{Binding NavigateHomeCommand}" />
                    <Button Style="{StaticResource MotionNavigationButton}" Content="控制卡连接" Command="{Binding NavigateConnectionCommand}" />
                    <Button Style="{StaticResource MotionNavigationButton}" Content="轴配置" Command="{Binding NavigateAxisConfigCommand}" />
                    <Button Style="{StaticResource MotionNavigationButton}" Content="单轴调试" Command="{Binding NavigateAxisDebugCommand}" />
                    <Button Style="{StaticResource MotionNavigationButton}" Content="IO 监控" Command="{Binding NavigateIoMonitorCommand}" />
                    <Button Style="{StaticResource MotionNavigationButton}" Content="点位调试" Command="{Binding NavigatePointDebugCommand}" />
                    <Button Style="{StaticResource MotionNavigationButton}" Content="多轴运动" Command="{Binding NavigateMultiAxisCommand}" />
                    <Button Style="{StaticResource MotionNavigationButton}" Content="报警诊断" Command="{Binding NavigateAlarmCommand}" />
                    <Button Style="{StaticResource MotionNavigationButton}" Content="运动日志" Command="{Binding NavigateLogCommand}" />
                </StackPanel>
                <Border DockPanel.Dock="Bottom" Margin="16" Padding="12" Background="#22FFFFFF" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Foreground="#FF94A3B8" Text="当前页面" />
                        <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding ActivePage}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>
        <ContentControl x:Name="WorkspaceContent" Grid.Column="1" Margin="18" />
    </Grid>
</UserControl>
