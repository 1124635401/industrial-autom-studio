<UserControl x:Class="IndustrialAutomationStudio.Modules.Motion.Views.MotionWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
        <ResourceDictionary Source="/IndustrialAutomationStudio.Modules.Motion;component/Resources/MotionTheme.xaml" />
    </UserControl.Resources>

    <Grid Background="{StaticResource MotionBrush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="{DynamicResource MotionStatusBarHeight}" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{DynamicResource MotionNavigationWidth}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{StaticResource MotionBrush.Navigation}"
                    BorderBrush="{StaticResource MotionBorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top" Margin="25,22,0,12" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource MotionTextSecondaryBrush}" Text="运动控制" />
                    <StackPanel>
                        <ToggleButton Style="{StaticResource MotionNavigationToggleStyle}"
                                      IsChecked="{Binding ActivePage, Mode=OneWay, Converter={StaticResource MotionEqualityConverter}, ConverterParameter=MotionHome}"
                                      Command="{Binding NavigateHomeCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="21" Height="21" Stretch="Uniform" StrokeThickness="1.6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource MotionIcon.Home}" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="运动首页" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MotionNavigationToggleStyle}"
                                      IsChecked="{Binding ActivePage, Mode=OneWay, Converter={StaticResource MotionEqualityConverter}, ConverterParameter=MotionConnection}"
                                      Command="{Binding NavigateConnectionCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="21" Height="21" Stretch="Uniform" StrokeThickness="1.6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource MotionIcon.Connection}" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="控制卡连接" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MotionNavigationToggleStyle}"
                                      IsChecked="{Binding ActivePage, Mode=OneWay, Converter={StaticResource MotionEqualityConverter}, ConverterParameter=MotionAxisConfig}"
                                      Command="{Binding NavigateAxisConfigCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="21" Height="21" Stretch="Uniform" StrokeThickness="1.6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource MotionIcon.Axis}" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="轴配置" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MotionNavigationToggleStyle}"
                                      IsChecked="{Binding ActivePage, Mode=OneWay, Converter={StaticResource MotionEqualityConverter}, ConverterParameter=MotionAxisDebug}"
                                      Command="{Binding NavigateAxisDebugCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="21" Height="21" Stretch="Uniform" StrokeThickness="1.6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource MotionIcon.Motion}" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="单轴调试" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MotionNavigationToggleStyle}"
                                      IsChecked="{Binding ActivePage, Mode=OneWay, Converter={StaticResource MotionEqualityConverter}, ConverterParameter=MotionIoMonitor}"
                                      Command="{Binding NavigateIoMonitorCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="21" Height="21" Stretch="Uniform" StrokeThickness="1.6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource MotionIcon.Io}" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="IO 监控" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MotionNavigationToggleStyle}"
                                      IsChecked="{Binding ActivePage, Mode=OneWay, Converter={StaticResource MotionEqualityConverter}, ConverterParameter=MotionPointDebug}"
                                      Command="{Binding NavigatePointDebugCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="21" Height="21" Stretch="Uniform" StrokeThickness="1.6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource MotionIcon.Point}" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="点位调试" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MotionNavigationToggleStyle}"
                                      IsChecked="{Binding ActivePage, Mode=OneWay, Converter={StaticResource MotionEqualityConverter}, ConverterParameter=MotionMultiAxis}"
                                      Command="{Binding NavigateMultiAxisCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="21" Height="21" Stretch="Uniform" StrokeThickness="1.6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource MotionIcon.MultiAxis}" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="多轴运动" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MotionNavigationToggleStyle}"
                                      IsChecked="{Binding ActivePage, Mode=OneWay, Converter={StaticResource MotionEqualityConverter}, ConverterParameter=MotionAlarm}"
                                      Command="{Binding NavigateAlarmCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="21" Height="21" Stretch="Uniform" StrokeThickness="1.6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource MotionIcon.Alarm}" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="报警诊断" />
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MotionNavigationToggleStyle}"
                                      IsChecked="{Binding ActivePage, Mode=OneWay, Converter={StaticResource MotionEqualityConverter}, ConverterParameter=MotionLog}"
                                      Command="{Binding NavigateLogCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="21" Height="21" Stretch="Uniform" StrokeThickness="1.6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="{StaticResource MotionIcon.Log}" />
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="运动日志" />
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentControl x:Name="WorkspaceContent" Grid.Column="1" Margin="26,22,26,20" />
        </Grid>

        <Border Grid.Row="1" Background="#FFFBFCFE" BorderBrush="{StaticResource MotionBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="26,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="49" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="49" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Fill="{StaticResource MotionBrush.Success}" />
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource MotionTextPrimaryBrush}" Text="在线" />
                </StackPanel>
                <Border Grid.Column="1" Height="20" Margin="24,0" Background="{StaticResource MotionBorderBrush}" />
                <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource MotionTextSecondaryBrush}"
                           Text="{Binding DriverLabel}" />
                <Border Grid.Column="3" Height="20" Margin="24,0" Background="{StaticResource MotionBorderBrush}" />
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource MotionTextSecondaryBrush}" Text="当前页面: " />
                    <TextBlock Foreground="{StaticResource MotionTextPrimaryBrush}" Text="{Binding ActivePageTitle}" />
                </StackPanel>
                <TextBlock Grid.Column="6" VerticalAlignment="Center" Foreground="{StaticResource MotionTextSecondaryBrush}"
                           Text="{Binding VersionText}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
