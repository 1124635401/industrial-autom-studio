<UserControl x:Class="IndustrialAutomationStudio.Modules.Motion.Views.Controls.AxisConfigurationHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid MinHeight="64">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel VerticalAlignment="Center">
            <TextBlock Style="{StaticResource MotionPageTitleStyle}" Text="轴配置" />
            <TextBlock Margin="0,5,0,0" FontSize="13"
                       Foreground="{StaticResource MotionTextSecondaryBrush}"
                       Text="配置和管理运动控制轴参数" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Margin="0,0,8,0" Style="{StaticResource MotionIconButtonStyle}" Command="{Binding LoadCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Width="17" Height="17" Margin="0,0,8,0" Stretch="Uniform" StrokeThickness="1.6"
                          Stroke="{StaticResource MotionBrush.Primary}" Data="{StaticResource MotionIcon.Folder}" />
                    <TextBlock VerticalAlignment="Center" Text="加载" />
                </StackPanel>
            </Button>
            <Button Margin="0,0,8,0" Style="{StaticResource MotionIconButtonStyle}" Command="{Binding SaveCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Width="17" Height="17" Margin="0,0,8,0" Stretch="Uniform" StrokeThickness="1.6"
                          Stroke="{StaticResource MotionBrush.Primary}" Data="{StaticResource MotionIcon.Save}" />
                    <TextBlock VerticalAlignment="Center" Text="保存" />
                </StackPanel>
            </Button>
            <Button Margin="0,0,8,0" Style="{StaticResource MotionIconButtonStyle}" Command="{Binding ImportCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Width="17" Height="17" Margin="0,0,8,0" Stretch="Uniform" StrokeThickness="1.6"
                          Stroke="{StaticResource MotionBrush.Primary}" Data="{StaticResource MotionIcon.Import}" />
                    <TextBlock VerticalAlignment="Center" Text="导入" />
                </StackPanel>
            </Button>
            <Button Margin="0,0,8,0" Style="{StaticResource MotionIconButtonStyle}" Command="{Binding ExportCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Width="17" Height="17" Margin="0,0,8,0" Stretch="Uniform" StrokeThickness="1.6"
                          Stroke="{StaticResource MotionBrush.Primary}" Data="{StaticResource MotionIcon.Export}" />
                    <TextBlock VerticalAlignment="Center" Text="导出" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource MotionIconButtonStyle}" Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Width="17" Height="17" Margin="0,0,8,0" Stretch="Uniform" StrokeThickness="1.6"
                          Stroke="{StaticResource MotionBrush.Primary}" Data="{StaticResource MotionIcon.Refresh}" />
                    <TextBlock VerticalAlignment="Center" Text="刷新" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
