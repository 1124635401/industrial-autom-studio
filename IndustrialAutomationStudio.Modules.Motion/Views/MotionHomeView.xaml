<UserControl x:Class="IndustrialAutomationStudio.Modules.Motion.Views.MotionHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <ScrollViewer>
        <StackPanel>
            <DockPanel Margin="0,0,0,18">
                <TextBlock FontSize="26" FontWeight="SemiBold" Text="运动首页" />
                <Button DockPanel.Dock="Right" Style="{StaticResource MotionPrimaryButton}" Content="刷新" Command="{Binding RefreshCommand}" />
            </DockPanel>
            <UniformGrid Columns="3">
                <GroupBox Header="控制卡"><TextBlock FontSize="24" Text="{Binding IsConnected, StringFormat={}已连接：{0}}" /></GroupBox>
                <GroupBox Header="轴数量"><TextBlock FontSize="24" Text="{Binding AxisCount}" /></GroupBox>
                <GroupBox Header="报警数量"><TextBlock FontSize="24" Text="{Binding AlarmCount}" /></GroupBox>
                <GroupBox Header="DI 数量"><TextBlock FontSize="24" Text="{Binding DiCount}" /></GroupBox>
                <GroupBox Header="DO 数量"><TextBlock FontSize="24" Text="{Binding DoCount}" /></GroupBox>
                <GroupBox Header="最近日志"><TextBlock Text="{Binding LatestLog}" TextWrapping="Wrap" /></GroupBox>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
