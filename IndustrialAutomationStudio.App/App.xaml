<prism:PrismApplication x:Class="IndustrialAutomationStudio.App.App"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:prism="http://prismlibrary.com/">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Make module resources available to the XAML designer before Prism initializes modules. -->
                <ResourceDictionary Source="/IndustrialAutomationStudio.Modules.Motion;component/Resources/MotionTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</prism:PrismApplication>
