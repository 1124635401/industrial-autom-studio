<Window x:Class="IndustrialAutomationStudio.App.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="{Binding Title}"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource MotionBrush.Background}"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="ShellCaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="54" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FF273142" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFEAF0F7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFDCE5F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ShellCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ShellCaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE5484D" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFC7373C" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#FFC9D6E6" BorderThickness="1" Background="{StaticResource MotionBrush.Background}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{DynamicResource MotionChromeHeight}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFF9FBFD" BorderBrush="{StaticResource MotionBorderBrush}"
                    BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="20,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="30" Height="30">
                            <Polygon Fill="{StaticResource MotionBrush.Primary}"
                                     Points="15,0 29,8 29,22 15,30 1,22 1,8" />
                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="10" FontWeight="Bold" Foreground="White" Text="IA" />
                        </Grid>
                        <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontSize="16"
                                   Foreground="{StaticResource MotionTextPrimaryBrush}"
                                   Text="Industrial Automation Studio 工业自动化调试平台" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource ShellCaptionButtonStyle}" Click="Minimize_OnClick"
                                AutomationProperties.Name="最小化">
                            <Path Width="13" Height="1" Stretch="Fill" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.4" Data="M0,0 L13,0" />
                        </Button>
                        <Button Style="{StaticResource ShellCaptionButtonStyle}" Click="Maximize_OnClick"
                                AutomationProperties.Name="最大化或还原">
                            <Path Width="13" Height="13" Stretch="Fill" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.25" Data="M1,1 L12,1 12,12 1,12 Z" />
                        </Button>
                        <Button Style="{StaticResource ShellCloseButtonStyle}" Click="Close_OnClick"
                                AutomationProperties.Name="关闭">
                            <Path Width="13" Height="13" Stretch="Fill" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.3" Data="M1,1 L12,12 M12,1 L1,12" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" prism:RegionManager.RegionName="MainContentRegion" />
        </Grid>
    </Border>
</Window>
